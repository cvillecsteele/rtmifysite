---
const navLinks = [
  { href: '/standards/as9100', label: 'AS9100' },
  { href: '/standards/iso-13485', label: 'ISO 13485' },
  { href: '/standards/do-178c', label: 'DO-178C' },
  { href: '/standards/iec-62304', label: 'IEC 62304' },
  { href: '/standards/iso-26262', label: 'ISO 26262' },
  { href: '/standards/aspice', label: 'ASPICE' },
];

const currentPath = Astro.url.pathname;
---

<nav class="bg-[#1A1A2E] text-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-14">
      <a href="/" class="font-semibold text-lg tracking-tight hover:text-gray-200 transition-colors">
        RTMify
      </a>
      <div class="hidden md:flex items-center gap-1 text-sm">
        {navLinks.map(link => (
          <a
            href={link.href}
            class={`px-3 py-1.5 rounded transition-colors text-sm ${
              currentPath === link.href || currentPath.startsWith(link.href)
                ? 'text-white border-b-2 border-white pb-[4px] font-medium'
                : 'text-white/60 hover:text-white hover:bg-white/10'
            }`}
          >
            {link.label}
          </a>
        ))}
        <a href="/download" class={`ml-2 px-3 py-1.5 rounded font-semibold transition-colors ${currentPath === '/download' ? 'text-white border-b-2 border-white pb-[4px]' : 'bg-white text-[#1A1A2E] hover:bg-gray-100'}`}>
          Download
        </a>
      </div>
      <!-- Mobile: just show Download -->
      <div class="md:hidden flex items-center gap-2">
        <a href="/download" class={`px-3 py-1.5 rounded font-semibold text-sm transition-colors ${currentPath === '/download' ? 'text-white border-b-2 border-white pb-[4px]' : 'bg-white text-[#1A1A2E] hover:bg-gray-100'}`}>
          Download
        </a>
      </div>
    </div>
  </div>
</nav>
