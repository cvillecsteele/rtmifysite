---
interface Props {
  href?: string;
  label?: string;
  size?: 'sm' | 'md' | 'lg';
}

const {
  href = '/RTMify_Requirements_Tracking_Template.xlsx',
  label = 'Download Template (.xlsx)',
  size = 'md',
} = Astro.props;

const sizeClasses = {
  sm: 'px-4 py-2 text-sm',
  md: 'px-6 py-3 text-base',
  lg: 'px-8 py-4 text-lg',
};
---

<a
  href={href}
  download
  class={`inline-flex items-center gap-2 bg-[#1A1A2E] text-white font-semibold rounded-lg hover:bg-[#2A2A4E] transition-colors ${sizeClasses[size]}`}
  data-plausible-event="Download Template"
>
  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
    <polyline points="7 10 12 15 17 10"/>
    <line x1="12" y1="15" x2="12" y2="3"/>
  </svg>
  {label}
</a>
