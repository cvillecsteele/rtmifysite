---
const standards = [
  { href: '/standards/as9100', label: 'AS9100' },
  { href: '/standards/iso-13485', label: 'ISO 13485' },
  { href: '/standards/do-178c', label: 'DO-178C' },
  { href: '/standards/iec-62304', label: 'IEC 62304' },
  { href: '/standards/iso-26262', label: 'ISO 26262' },
  { href: '/standards/aspice', label: 'ASPICE' },
];
---

<footer class="bg-[#1A1A2E] text-gray-400 border-t border-white/10 mt-auto">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-8">
      <div class="col-span-2 md:col-span-3 lg:col-span-1">
        <a href="/" class="text-white font-semibold text-lg">RTMify</a>
        <p class="mt-2 text-sm">Requirements traceability templates for regulated-industry engineers.</p>
      </div>
      <div>
        <h3 class="text-white text-sm font-semibold mb-3">Standards</h3>
        <ul class="space-y-2 text-sm">
          {standards.map(s => (
            <li><a href={s.href} class="hover:text-white transition-colors">{s.label}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <h3 class="text-white text-sm font-semibold mb-3">Products</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/download" class="hover:text-white transition-colors">RTMify Template</a></li>
          <li><a href="/trace" class="hover:text-white transition-colors">RTMify Trace</a></li>
          <li><a href="/live" class="hover:text-white transition-colors">RTMify Live</a></li>
          <li><a href="/pricing" class="hover:text-white transition-colors">Pricing</a></li>
          <li><a href="/docs" class="hover:text-white transition-colors">Documentation</a></li>
          <li><a href="/validation" class="hover:text-white transition-colors">IQ/OQ Validation</a></li>
        </ul>
      </div>
      <div>
        <h3 class="text-white text-sm font-semibold mb-3">Free Templates</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/free-templates/fmea" class="hover:text-white transition-colors">FMEA Template</a></li>
          <li><a href="/free-templates" class="hover:text-white transition-colors">All free templates →</a></li>
        </ul>
      </div>
      <div>
        <h3 class="text-white text-sm font-semibold mb-3">Company</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="mailto:hello@rtmify.io" class="hover:text-white transition-colors">hello@rtmify.io</a></li>
          <li><a href="/about" class="hover:text-white transition-colors">About</a></li>
          <li><a href="/blog" class="hover:text-white transition-colors">Blog</a></li>
          <li><a href="/terms" class="hover:text-white transition-colors">Terms</a></li>
          <li><a href="/privacy" class="hover:text-white transition-colors">Privacy</a></li>
          <li><a href="/license" class="hover:text-white transition-colors">License (EULA)</a></li>
        </ul>
      </div>
    </div>
    <div class="mt-10 pt-8 border-t border-white/10 text-sm text-center">
      <p>&copy; {new Date().getFullYear()} Iron Brothers Ventures, LLC.</p>
      <p class="mt-1">Because audits shouldn't take years off your life.</p>
    </div>
  </div>
</footer>
