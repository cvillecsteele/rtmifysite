---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const url = Astro.url;
const order_id   = url.searchParams.get('order_id')   ?? '';
const email      = url.searchParams.get('email')      ?? '';
const total      = url.searchParams.get('total')      ?? '';
const license_key = url.searchParams.get('license_key') ?? '';

const valid = license_key.length > 0;
---

<BaseLayout
  title="Order Confirmed — RTMify Trace"
  description="Your RTMify Trace order is confirmed. Follow the instructions below to install your signed license file."
>
  <Nav />

  <main class="flex-1 py-16 px-4">
    <div class="max-w-2xl mx-auto">

      {valid ? (
        <>
          <!-- Success -->
          <div class="flex items-center gap-3 mb-8">
            <div class="w-10 h-10 rounded-full bg-green-100 flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <h1 class="text-2xl font-bold text-[#1A1A2E]">Order confirmed</h1>
          </div>

          {email && (
            <p class="text-[#555555] mb-8">
              A receipt has been sent to <strong class="text-[#1A1A2E]">{email}</strong>.
            </p>
          )}

          <!-- License delivery -->
          <div class="bg-[#F5F5F5] border border-[#DDDDDD] rounded-xl p-6 mb-8">
            <p class="text-xs font-semibold text-[#555555] uppercase tracking-widest mb-2">Signed license file</p>
            <p class="text-sm text-[#555555] mb-3">Your RTMify Trace license is delivered as a signed <code>license.json</code> file, not a machine-activation key.</p>
            <p class="text-xs text-[#555555] m-0">If you do not see the license file attached to your purchase confirmation email, contact <a href="mailto:hello@rtmify.io" class="underline hover:text-[#1A1A2E]">hello@rtmify.io</a> with your order details.</p>
          </div>

          <!-- Activation instructions -->
          <div class="mb-8">
            <h2 class="text-lg font-bold text-[#1A1A2E] mb-4">How to activate</h2>
            <ol class="space-y-4">
              <li class="flex gap-4 items-start">
                <span class="shrink-0 w-6 h-6 rounded-full bg-[#1A1A2E] text-white text-xs font-bold flex items-center justify-center">1</span>
                <div>
                  <p class="text-[#1A1A2E] font-medium">Download RTMify Trace</p>
                  <p class="text-sm text-[#555555]">
                    Get the binary for your platform from <a href="/trace" class="underline hover:text-[#1A1A2E]">rtmify.io/trace</a>.
                  </p>
                </div>
              </li>
              <li class="flex gap-4 items-start">
                <span class="shrink-0 w-6 h-6 rounded-full bg-[#1A1A2E] text-white text-xs font-bold flex items-center justify-center">2</span>
                <div>
                  <p class="text-[#1A1A2E] font-medium">Install the signed license file</p>
                  <pre class="mt-2 bg-[#1A1A2E] text-green-400 font-mono text-sm rounded-lg px-4 py-3 overflow-x-auto"><code>rtmify-trace license install /path/to/license.json</code></pre>
                </div>
              </li>
              <li class="flex gap-4 items-start">
                <span class="shrink-0 w-6 h-6 rounded-full bg-[#1A1A2E] text-white text-xs font-bold flex items-center justify-center">3</span>
                <div>
                  <p class="text-[#1A1A2E] font-medium">You're done</p>
                  <p class="text-sm text-[#555555]">The signed license file is verified locally. Run RTMify Trace on any <code class="bg-[#F5F5F5] px-1 py-0.5 rounded text-xs">.xlsx</code> file — no runtime internet connection is required.</p>
                </div>
              </li>
            </ol>
          </div>

          <!-- Order details -->
          {(order_id || total) && (
            <div class="border-t border-[#DDDDDD] pt-6 text-sm text-[#555555] space-y-1">
              {order_id && <p>Order <span class="font-mono">{order_id}</span></p>}
              {total    && <p>Total charged: {total}</p>}
            </div>
          )}

          <!-- Moving to another machine -->
          <div class="mt-8 bg-blue-50 border border-blue-100 rounded-xl p-5 text-sm text-[#555555]">
            <p class="font-semibold text-[#1A1A2E] mb-1">Moving to a new machine?</p>
            <p>Copy the signed <code>license.json</code> file to the new machine or install it there with <code>rtmify-trace license install /path/to/license.json</code>.</p>
          </div>
        </>
      ) : (
        <!-- No license key in URL -->
        <div class="text-center py-16">
          <h1 class="text-2xl font-bold text-[#1A1A2E] mb-3">No order found</h1>
          <p class="text-[#555555] mb-6">This page is only valid when reached directly from a purchase confirmation.</p>
          <p class="text-[#555555]">If you completed a purchase and didn't receive your signed license file, <a href="mailto:hello@rtmify.io" class="underline hover:text-[#1A1A2E]">email us</a> with your order ID.</p>
        </div>
      )}

    </div>
  </main>

  <Footer />
</BaseLayout>
