---
import DocsLayout from '../../../layouts/DocsLayout.astro';

const title = 'RTMify Live: Real-Time Requirements Traceability';
const description = 'RTMify Live watches your spreadsheet and your codebase, keeps traceability up to date automatically, and answers questions about coverage through an MCP integration for AI assistants.';
const canonical = 'https://rtmify.io/docs/live/';

const breadcrumbs = [
  { name: 'RTMify', url: '/' },
  { name: 'Docs', url: '/docs/' },
  { name: 'Live', url: '/docs/live/' }
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "RTMify", "item": "https://rtmify.io/" },
    { "@type": "ListItem", "position": 2, "name": "Docs", "item": "https://rtmify.io/docs/" },
    { "@type": "ListItem", "position": 3, "name": "Live", "item": "https://rtmify.io/docs/live/" }
  ]
};
---

<DocsLayout
  title={title}
  description={description}
  canonical={canonical}
  jsonLd={jsonLd}
  breadcrumbs={breadcrumbs}
  activeSlug="live-overview"
  lane="live"
>
  <div class="mb-10">
    <div class="flex items-center gap-3 mb-4">
      <span class="w-3 h-3 rounded-full bg-[#2E7D32] shrink-0"></span>
      <span class="text-sm font-semibold text-[#2E7D32] uppercase tracking-wide">Live</span>
    </div>
    <h1 class="text-4xl md:text-5xl font-bold text-[#1A1A2E] mb-4" style="font-family: var(--font-family-display);">
      RTMify Live
    </h1>
    <p class="text-lg text-[#555555] max-w-2xl leading-relaxed">
      A local server that keeps your traceability graph synchronized with both your spreadsheet and your codebase — in real time.
    </p>
  </div>

  <!-- What it does -->
  <section class="mb-12">
    <h2 class="text-2xl font-bold text-[#1A1A2E] mb-4" style="font-family: var(--font-family-display);">What it does</h2>
    <p class="text-[#555555] mb-6">RTMify Live runs as a background process on your machine. It watches your .xlsx template for changes, scans your source and test files for requirement annotations, ingests test results from your CI pipeline, and maintains a live graph of your entire traceability chain.</p>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="p-5 border border-[#DDDDDD] rounded-lg">
        <h3 class="text-base font-bold text-[#1A1A2E] mb-2">Spreadsheet sync</h3>
        <p class="text-[#555555] text-sm m-0">Watches your template for changes. Status cells update automatically as you add or fix requirements.</p>
      </div>
      <div class="p-5 border border-[#DDDDDD] rounded-lg">
        <h3 class="text-base font-bold text-[#1A1A2E] mb-2">Repo scanning</h3>
        <p class="text-[#555555] text-sm m-0">Scans your codebase for <code style="font-family: var(--font-family-mono); font-size: 0.8125rem; background: #F5F5F5; padding: 0 0.3rem; border-radius: 0.2rem;">@req</code> annotations. Surfaces where each requirement is implemented and tested.</p>
      </div>
      <div class="p-5 border border-[#DDDDDD] rounded-lg">
        <h3 class="text-base font-bold text-[#1A1A2E] mb-2">Test results API</h3>
        <p class="text-[#555555] text-sm m-0">Accepts test result ingestion from CI pipelines. Maps pass/fail status back to requirements automatically.</p>
      </div>
      <div class="p-5 border border-[#DDDDDD] rounded-lg">
        <h3 class="text-base font-bold text-[#1A1A2E] mb-2">MCP integration</h3>
        <p class="text-[#555555] text-sm m-0">Exposes a Model Context Protocol server so AI assistants (Claude, Cursor, etc.) can query your traceability graph directly.</p>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="mb-12 border-t border-[#DDDDDD] pt-10">
    <h2 class="text-2xl font-bold text-[#1A1A2E] mb-4" style="font-family: var(--font-family-display);">How it works</h2>

    <div class="space-y-6">
      <div>
        <h3 class="text-base font-bold text-[#1A1A2E] mb-2">The graph</h3>
        <p class="text-[#555555] text-sm">Live maintains a directed graph that connects every node in your traceability chain: user needs → requirements → tests → risks, plus design inputs, design outputs, source files, test files, and CI annotations. Every edge is typed and timestamped.</p>
      </div>
      <div>
        <h3 class="text-base font-bold text-[#1A1A2E] mb-2">Profiles</h3>
        <p class="text-[#555555] text-sm">Live adapts to your regulatory context. The <strong>medical</strong> profile adds design input/output tabs and risk-control linkage. The <strong>aerospace</strong> profile adds configuration items and CI evidence. <strong>Automotive</strong> adds ASPICE SWE process evidence. The <strong>generic</strong> profile covers everything else.</p>
      </div>
      <div>
        <h3 class="text-base font-bold text-[#1A1A2E] mb-2">Dashboard</h3>
        <p class="text-[#555555] text-sm">A local web UI at <code style="font-family: var(--font-family-mono); font-size: 0.8125rem; background: #F5F5F5; padding: 0 0.3rem; border-radius: 0.2rem;">http://localhost:8000</code> shows your live traceability graph, coverage metrics, gap reports, and recent test results.</p>
      </div>
    </div>
  </section>

  <!-- Annotation syntax -->
  <section class="mb-12 border-t border-[#DDDDDD] pt-10">
    <h2 class="text-2xl font-bold text-[#1A1A2E] mb-4" style="font-family: var(--font-family-display);">Annotation syntax</h2>
    <p class="text-[#555555] mb-4 text-sm">Add <code style="font-family: var(--font-family-mono); font-size: 0.8125rem; background: #F5F5F5; padding: 0 0.3rem; border-radius: 0.2rem;">@req</code> comments to your source and test files. Live scans for these on every sync cycle.</p>

    <div class="space-y-4">
      <div>
        <p class="text-xs font-semibold text-[#555555] uppercase tracking-wide mb-2">Implementation annotation</p>
        <pre class="bg-[#F5F5F5] border border-[#DDDDDD] rounded p-4 text-sm overflow-x-auto" style="font-family: var(--font-family-mono);">// @req REQ-042 Validate input before processing
function validatePayload(data) &#123;
  // ...
&#125;</pre>
      </div>
      <div>
        <p class="text-xs font-semibold text-[#555555] uppercase tracking-wide mb-2">Test annotation</p>
        <pre class="bg-[#F5F5F5] border border-[#DDDDDD] rounded p-4 text-sm overflow-x-auto" style="font-family: var(--font-family-mono);">// @req REQ-042 @test TG-007
test('rejects malformed payload', () =&gt; &#123;
  // ...
&#125;);</pre>
      </div>
    </div>
  </section>

  <!-- Coming soon note -->
  <section class="border border-[#2E7D32] border-opacity-30 bg-[#F1F8F2] rounded-lg p-6">
    <h2 class="text-base font-bold text-[#2E7D32] mb-2 m-0">Detailed docs coming soon</h2>
    <p class="text-[#555555] text-sm m-0">Full setup guides, configuration reference, API documentation, and the MCP integration guide are in progress. If you want early access, <a href="/download" class="text-[#2E7D32] underline hover:no-underline">join the waitlist</a>.</p>
  </section>
</DocsLayout>
