---
import DocsLayout from '../../layouts/DocsLayout.astro';

const title = 'RTMify Documentation';
const description = 'Documentation for the full RTMify product family: the requirements traceability template, RTMify Trace for generating RTM packages, and RTMify Live for real-time traceability against your codebase.';
const canonical = 'https://rtmify.io/docs';

const breadcrumbs = [
  { name: 'RTMify', url: '/' },
  { name: 'Docs', url: '/docs' }
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "RTMify", "item": { "@id": "https://rtmify.io/" } },
    { "@type": "ListItem", "position": 2, "name": "Docs", "item": { "@id": "https://rtmify.io/docs/" } }
  ]
};
---

<DocsLayout
  title={title}
  description={description}
  canonical={canonical}
  jsonLd={jsonLd}
  breadcrumbs={breadcrumbs}
  activeSlug="docs"
  lane="hub"
>
  <div class="mb-4">
    <h1 class="text-4xl md:text-5xl font-bold text-[#1A1A2E] mb-4" style="font-family: var(--font-family-display);">
      Documentation
    </h1>
    <p class="text-lg text-[#555555] max-w-2xl leading-relaxed">
      RTMify is a three-part system. Pick the lane that matches what you're working on.
    </p>
  </div>

  <!-- Three product lanes -->
  <div class="space-y-4 mt-10">

    <!-- Template -->
    <a href="/docs/template" class="flex gap-6 p-6 border border-[#DDDDDD] rounded-lg hover:shadow-md transition-shadow no-underline group">
      <div class="flex-shrink-0 mt-1">
        <span class="flex items-center justify-center w-9 h-9 rounded-full bg-[#1A1A2E]">
          <span class="text-white text-base font-bold" style="font-family: var(--font-family-mono);">T</span>
        </span>
      </div>
      <div>
        <h2 class="text-xl font-bold text-[#1A1A2E] mb-1 m-0 group-hover:underline" style="font-family: var(--font-family-display);">Template</h2>
        <p class="text-[#555555] m-0 text-base leading-relaxed">The .xlsx file. Four tabs — User Needs, Requirements, Tests, Risks — that satisfies traceability requirements for AS9100, ISO 13485, DO-178C, IEC 62304, ISO 26262, and ASPICE. Field-by-field reference documentation.</p>
        <p class="text-[#888888] text-sm m-0 mt-2">Field reference · Status codes · Traceability chain · Quick starts for 6 standards</p>
      </div>
    </a>

    <!-- Trace -->
    <a href="/docs/trace" class="flex gap-6 p-6 border border-[#DDDDDD] rounded-lg hover:shadow-md transition-shadow no-underline group">
      <div class="flex-shrink-0 mt-1">
        <span class="flex items-center justify-center w-9 h-9 rounded-full bg-[#1565C0]">
          <span class="text-white text-base font-bold" style="font-family: var(--font-family-mono);">&rarr;</span>
        </span>
      </div>
      <div>
        <h2 class="text-xl font-bold text-[#1A1A2E] mb-1 m-0 group-hover:underline" style="font-family: var(--font-family-display);">Trace</h2>
        <p class="text-[#555555] m-0 text-base leading-relaxed">The desktop app. Drop your filled-in template onto RTMify Trace and get a full requirements traceability matrix as PDF, Word, or Markdown. Runs locally — nothing is uploaded.</p>
        <p class="text-[#888888] text-sm m-0 mt-2">Running Trace · Output formats · Gap summary · Validation package</p>
      </div>
    </a>

    <!-- Live -->
    <a href="/docs/live" class="flex gap-6 p-6 border border-[#DDDDDD] rounded-lg hover:shadow-md transition-shadow no-underline group">
      <div class="flex-shrink-0 mt-1">
        <span class="flex items-center justify-center w-9 h-9 rounded-full bg-[#2E7D32]">
          <span class="text-white text-base font-bold" style="font-family: var(--font-family-mono);">&#9679;</span>
        </span>
      </div>
      <div>
        <h2 class="text-xl font-bold text-[#1A1A2E] mb-1 m-0 group-hover:underline" style="font-family: var(--font-family-display);">Live</h2>
        <p class="text-[#555555] m-0 text-base leading-relaxed">The local server. RTMify Live watches your spreadsheet and your codebase, keeps traceability up to date in real time, answers questions about coverage through an MCP integration, and surfaces gaps before audits do.</p>
        <p class="text-[#888888] text-sm m-0 mt-2">Setup · The graph · Repo scanning · Test results API · MCP integration · Dashboard</p>
      </div>
    </a>

  </div>

  <!-- Standards quick links -->
  <section class="mt-16 border-t border-[#DDDDDD] pt-12">
    <h2 class="text-2xl font-bold text-[#1A1A2E] mb-2" style="font-family: var(--font-family-display);">
      Quick starts by standard
    </h2>
    <p class="text-[#555555] mb-6 text-sm">Jump straight to the template guide for your regulatory context.</p>
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
      <a href="/docs/for/as9100" class="block p-4 border border-[#DDDDDD] rounded-lg hover:shadow-md transition-shadow no-underline" style="border-left: 4px solid #1565C0;">
        <span class="text-sm font-bold" style="color: #1565C0;">AS9100</span>
        <p class="text-[#555555] text-xs m-0 mt-1">Aerospace quality. §8.3 design controls.</p>
      </a>
      <a href="/docs/for/iso-13485" class="block p-4 border border-[#DDDDDD] rounded-lg hover:shadow-md transition-shadow no-underline" style="border-left: 4px solid #2E7D32;">
        <span class="text-sm font-bold" style="color: #2E7D32;">ISO 13485</span>
        <p class="text-[#555555] text-xs m-0 mt-1">Medical devices. §7.3 design controls.</p>
      </a>
      <a href="/docs/for/do-178c" class="block p-4 border border-[#DDDDDD] rounded-lg hover:shadow-md transition-shadow no-underline" style="border-left: 4px solid #6A1B9A;">
        <span class="text-sm font-bold" style="color: #6A1B9A;">DO-178C</span>
        <p class="text-[#555555] text-xs m-0 mt-1">Airborne software. HLR/LLR, DAL A–E.</p>
      </a>
      <a href="/docs/for/iec-62304" class="block p-4 border border-[#DDDDDD] rounded-lg hover:shadow-md transition-shadow no-underline" style="border-left: 4px solid #BF360C;">
        <span class="text-sm font-bold" style="color: #BF360C;">IEC 62304</span>
        <p class="text-[#555555] text-xs m-0 mt-1">Medical device software. Class A/B/C.</p>
      </a>
      <a href="/docs/for/iso-26262" class="block p-4 border border-[#DDDDDD] rounded-lg hover:shadow-md transition-shadow no-underline" style="border-left: 4px solid #E65100;">
        <span class="text-sm font-bold" style="color: #E65100;">ISO 26262</span>
        <p class="text-[#555555] text-xs m-0 mt-1">Automotive functional safety. HARA, ASIL.</p>
      </a>
      <a href="/docs/for/aspice" class="block p-4 border border-[#DDDDDD] rounded-lg hover:shadow-md transition-shadow no-underline" style="border-left: 4px solid #004D40;">
        <span class="text-sm font-bold" style="color: #004D40;">ASPICE</span>
        <p class="text-[#555555] text-xs m-0 mt-1">Automotive SPICE. SYS.2/SWE.1–6.</p>
      </a>
    </div>
  </section>
</DocsLayout>
