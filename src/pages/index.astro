---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import DownloadButton from '../components/DownloadButton.astro';
import StatusBadge from '../components/StatusBadge.astro';

const standards = [
  { slug: 'as9100', label: 'AS9100', color: '#1565C0' },
  { slug: 'iso-13485', label: 'ISO 13485', color: '#2E7D32' },
  { slug: 'do-178c', label: 'DO-178C', color: '#6A1B9A' },
  { slug: 'iec-62304', label: 'IEC 62304', color: '#BF360C' },
  { slug: 'iso-26262', label: 'ISO 26262', color: '#E65100' },
  { slug: 'aspice', label: 'ASPICE', color: '#004D40' },
];
---

<BaseLayout
  title="RTMify — Requirements Traceability Matrix Templates for Regulated Industries"
  description="Free RTM template for AS9100, ISO 13485, DO-178C, IEC 62304, ISO 26262, and Automotive SPICE. Download .xlsx, generate PDF. Nothing leaves your machine."
>
  <Nav />

  <main class="flex-1">
    <!-- Hero -->
    <section class="bg-[#1A1A2E] text-white py-20 px-4">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="text-4xl md:text-6xl font-bold mb-5 tracking-tight">
          Your RTM.<br />Done tonight.
        </h1>
        <p class="text-lg md:text-xl text-gray-300 mb-8 max-w-2xl mx-auto">
          A requirements traceability template that works the way you actually work, in a spreadsheet.
          Free download. Nothing leaves your machine.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
          <DownloadButton size="lg" />
          <a href="#how-it-works" class="text-gray-300 hover:text-white transition-colors text-base">
            Learn more ↓
          </a>
        </div>
      </div>
    </section>

    <!-- Standards Coverage Bar -->
    <section class="bg-[#2A2A4E] py-5 px-4">
      <div class="max-w-4xl mx-auto">
        <div class="flex flex-wrap gap-3 justify-center items-center">
          <span class="text-gray-400 text-sm mr-1">Covers:</span>
          {standards.map(s => (
            <a
              href={`/standards/${s.slug}`}
              class="inline-flex items-center px-3 py-1 rounded-full text-sm font-semibold text-white transition-opacity hover:opacity-80"
              style={`background-color: ${s.color};`}
            >
              {s.label}
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- What It Does (3-column) -->
    <section class="py-16 px-4 bg-white">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-2xl font-bold text-[#1A1A2E] text-center mb-10">What the template does</h2>
        <div class="grid md:grid-cols-3 gap-8">
          <div class="border border-[#DDDDDD] rounded-lg p-6">
            <h3 class="font-bold text-[#1A1A2E] text-lg mb-2">Four tabs. One schema.</h3>
            <p class="text-[#555555]">User Needs, Requirements, Tests, Risks. The relationships that every audit cares about, in a structure your team already knows how to use.</p>
          </div>
          <div class="border border-[#DDDDDD] rounded-lg p-6">
            <h3 class="font-bold text-[#1A1A2E] text-lg mb-2">RTMify Status column.</h3>
            <p class="text-[#555555] mb-3">After each sync, every row gets a status. Gaps surface before the auditor does.</p>
            <div class="flex flex-wrap gap-2">
              <StatusBadge status="OK" />
              <StatusBadge status="NO_TEST_LINKED" />
              <StatusBadge status="MISSING_ID" />
            </div>
          </div>
          <div class="border border-[#DDDDDD] rounded-lg p-6">
            <h3 class="font-bold text-[#1A1A2E] text-lg mb-2">Generate an RTM.</h3>
            <p class="text-[#555555]">Drop the file on the RTMify binary. Get a PDF with requirements, tests, risks, and a full traceability matrix. Nothing leaves your laptop.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- How It Works -->
    <section id="how-it-works" class="py-16 px-4 bg-[#F5F5F5]">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-2xl font-bold text-[#1A1A2E] text-center mb-10">How it works</h2>
        <ol class="space-y-6">
          {[
            { n: 1, title: 'Download the template', desc: 'Free .xlsx file. No account, no email, no friction.' },
            { n: 2, title: 'Fill in your requirements, tests, risks', desc: 'Use the four tabs: User Needs, Requirements, Tests, Risks. Add your IDs, descriptions, and cross-references.' },
            { n: 3, title: 'Drop the file on the RTMify binary', desc: 'Local tool. Runs on your machine. No internet connection required.' },
            { n: 4, title: 'Get a PDF RTM', desc: 'Full traceability matrix from requirements to tests to risks. Print it. Email it. Put it in your technical file.' },
          ].map(step => (
            <li class="flex gap-5 items-start">
              <span class="w-9 h-9 rounded-full bg-[#1A1A2E] text-white font-bold flex items-center justify-center shrink-0 text-sm">
                {step.n}
              </span>
              <div>
                <h3 class="font-semibold text-[#1A1A2E] mb-1">{step.title}</h3>
                <p class="text-[#555555]">{step.desc}</p>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <!-- Social Proof / Credibility -->
    <section class="py-16 px-4 bg-white border-t border-[#DDDDDD]">
      <div class="max-w-3xl mx-auto text-center">
        <blockquote class="text-xl text-[#1A1A2E] font-medium italic">
          "Built for engineers who've been in the audit room."
        </blockquote>
        <p class="mt-4 text-[#555555] text-sm">Designed by people who've written RTMs at 11pm the night before an audit. We know what actually gets flagged.</p>
      </div>
    </section>

    <!-- Standards deep-dives -->
    <section class="py-16 px-4 bg-[#F5F5F5]">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-2xl font-bold text-[#1A1A2E] text-center mb-4">Standard-specific guidance</h2>
        <p class="text-[#555555] text-center mb-10 max-w-2xl mx-auto">The template covers all six standards. Each standards page explains exactly what the standard requires, what the template covers, and where teams typically miss.</p>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {standards.map(s => (
            <a
              href={`/standards/${s.slug}`}
              class="group block border border-[#DDDDDD] rounded-lg p-5 bg-white hover:shadow-md transition-shadow"
            >
              <div
                class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold text-white mb-3"
                style={`background-color: ${s.color};`}
              >
                {s.label}
              </div>
              <h3 class="font-semibold text-[#1A1A2E] group-hover:underline">{s.label} RTM Template</h3>
              <p class="text-sm text-[#555555] mt-1">Clause references, common audit gaps, and traceability guidance.</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Footer CTA -->
    <section class="py-16 px-4 bg-[#1A1A2E] text-center">
      <div class="max-w-2xl mx-auto">
        <h2 class="text-2xl font-bold text-white mb-3">Download the template</h2>
        <p class="text-gray-300 mb-6">Free. No account. No email. Works in Excel and Google Sheets.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
          <DownloadButton size="lg" />
          <a href="/about" class="text-gray-300 hover:text-white transition-colors">
            Learn about RTMify →
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
