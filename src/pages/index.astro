---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import DownloadButton from '../components/DownloadButton.astro';
import StatusBadge from '../components/StatusBadge.astro';
import ConversationDemo from '../components/ConversationDemo.astro';

const standards = [
  { slug: 'as9100', label: 'AS9100', color: '#1565C0', desc: 'Aerospace quality management. §8.3 design controls, traceability, and configuration management.' },
  { slug: 'iso-13485', label: 'ISO 13485', color: '#2E7D32', desc: 'Medical device QMS. §7.3 design inputs, outputs, V&V, and risk per ISO 14971.' },
  { slug: 'do-178c', label: 'DO-178C', color: '#6A1B9A', desc: 'Airborne software. HLR/LLR traceability, DAL annotation, bidirectional coverage.' },
  { slug: 'iec-62304', label: 'IEC 62304', color: '#BF360C', desc: 'Medical device software lifecycle. §5.2–5.7, safety class, SOUP tracking.' },
  { slug: 'iso-26262', label: 'ISO 26262', color: '#E65100', desc: 'Automotive functional safety. HARA, ASIL assignment, V-model traceability.' },
  { slug: 'aspice', label: 'ASPICE', color: '#004D40', desc: 'Automotive SPICE. SYS.2/SWE.1–6 bidirectional traceability and capability evidence.' },
];

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'RTMify',
  url: 'https://rtmify.io',
  description: 'Free requirements traceability matrix templates for regulated industries. Covers AS9100, ISO 13485, DO-178C, IEC 62304, ISO 26262, and Automotive SPICE.',
};
---

<BaseLayout
  title="RTMify — Free Requirements Traceability Matrix Template"
  description="Free RTM template for AS9100, ISO 13485, DO-178C, IEC 62304, ISO 26262, and Automotive SPICE. Download .xlsx, generate PDF. Nothing leaves your machine."
  jsonLd={organizationSchema}
>
  <Nav />

  <main class="flex-1">
    <!-- Hero -->
    <section class="hero-texture bg-[#1A1A2E] text-white py-20 px-4">
      <div class="max-w-4xl mx-auto text-center">
        <div class="animate-hero-1">
          <h1 class="text-4xl md:text-[60px] md:leading-[1.15] font-bold mb-5 tracking-tight" style="font-family: var(--font-family-display);">
            Your RTM.<br />Done tonight.
          </h1>
        </div>
        <div class="animate-hero-2">
          <p class="text-lg md:text-xl text-gray-300 mb-8 max-w-2xl mx-auto">
            A requirements traceability template that works the way you actually work, in a spreadsheet.
            Free download. Nothing leaves your machine.
          </p>
        </div>
        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center animate-hero-3">
          <DownloadButton size="lg" variant="light" />
          <a href="#how-it-works" class="text-gray-300 hover:text-white transition-colors text-base">
            Learn more ↓
          </a>
        </div>
      </div>
    </section>

    <!-- Standards Coverage Bar -->
    <section class="bg-white border-b border-[#DDDDDD] py-5 px-4">
      <div class="max-w-4xl mx-auto">
        <div class="flex flex-wrap gap-3 justify-center items-center">
          <span class="text-[#555555] text-sm mr-1">Covers:</span>
          {standards.map(s => (
            <a
              href={`/standards/${s.slug}`}
              class="inline-flex items-center px-3 py-1 rounded-full text-sm font-semibold text-white transition-opacity hover:opacity-80"
              style={`background-color: ${s.color};`}
            >
              {s.label}
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Free Templates bar -->
    <section class="bg-[#F5F5F5] border-b border-[#DDDDDD] py-4 px-4">
      <div class="max-w-4xl mx-auto text-center text-sm text-[#555555]">
        Need standalone risk management or SOUP templates? <a href="/free-templates" class="text-[#1A1A2E] font-semibold underline underline-offset-2 hover:opacity-70 transition-opacity">Free FMEA, hazard log, SOUP, and BOM templates →</a>
      </div>
    </section>

    <!-- What It Does (3-column) -->
    <section class="py-16 px-4 bg-white">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-2xl font-bold text-[#1A1A2E] text-center mb-10">How to make audits not suck</h2>
        <div class="grid md:grid-cols-3 gap-8">
          <div class="border border-[#DDDDDD] rounded-lg p-6">
            <h3 class="font-bold text-[#1A1A2E] text-lg mb-2">Four tabs. One schema.</h3>
            <p class="text-[#555555]">User Needs, Requirements, Tests, Risks. The relationships that every audit cares about, in a structure your team already knows how to use.</p>
          </div>
          <div class="border border-[#DDDDDD] rounded-lg p-6">
            <h3 class="font-bold text-[#1A1A2E] text-lg mb-2">Generate an RTM.</h3>
            <p class="text-[#555555] mb-3">Check your audit status: just drag &amp; drop the file onto <a href="/trace" class="underline hover:text-[#1A1A2E]">RTMify Trace</a>. Get a full analysis and your RTM.</p>
            <div class="flex flex-wrap gap-2">
              <code class="font-mono text-xs font-semibold px-2 py-0.5 rounded" style="background-color: #DBEAFE; color: #1E40AF; font-family: var(--font-family-mono);">.docx</code>
              <code class="font-mono text-xs font-semibold px-2 py-0.5 rounded" style="background-color: #FEE2E2; color: #991B1B; font-family: var(--font-family-mono);">.pdf</code>
              <code class="font-mono text-xs font-semibold px-2 py-0.5 rounded" style="background-color: #DCFCE7; color: #166534; font-family: var(--font-family-mono);">.md</code>
            </div>
          </div>
          <div class="border border-[#DDDDDD] rounded-lg p-6">
            <h3 class="font-bold text-[#1A1A2E] text-lg mb-2">Live traceability updates.</h3>
            <p class="text-[#555555] mb-3">Using <a href="/trace" class="underline hover:text-[#1A1A2E]">RTMify Live</a>: whenever anyone touches a cell in the sheet, every row gets a realtime status update. Gaps surface <i>before the auditor does.</i></p>
            <div class="flex flex-wrap gap-2">
              <StatusBadge status="OK" />
              <StatusBadge status="NO_TEST_LINKED" />
              <StatusBadge status="MISSING_ID" />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- How It Works -->
    <section id="how-it-works" class="py-16 px-4 bg-[#F5F5F5]">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-2xl font-bold text-[#1A1A2E] text-center mb-10">How it works</h2>
        <ol class="relative">
          {[
            { n: 1, title: 'Download the template', desc: 'Free .xlsx file. No account, no email, no friction.' },
            { n: 2, title: 'Fill in your requirements, tests, risks', desc: 'Use the four tabs: User Needs, Requirements, Tests, Risks. Add your IDs, descriptions, and cross-references.' },
            { n: 3, title: <>Drop the file on <a href="/trace" class="underline hover:text-[#1A1A2E]">RTMify Trace</a></>, desc: 'Runs on your machine. No need to call IT, your data always stays local.' },
            { n: 4, title: 'Get an RTM as a PDF / Word Doc / Markdown', desc: 'Full traceability matrix from requirements to tests to risks. Print it. Email it. Put it in your technical file. Dazzle your friends.' },
          ].map((step, i) => (
            <li class="flex gap-5 items-start relative pb-6 last:pb-0">
              {i < 3 && (
                <div class="absolute left-[17px] top-9 bottom-0 w-px bg-[#DDDDDD]" aria-hidden="true"></div>
              )}
              <span class="relative z-10 w-9 h-9 rounded-full bg-[#1A1A2E] text-white font-bold flex items-center justify-center shrink-0 text-sm">
                {step.n}
              </span>
              <div>
                <h3 class="font-semibold text-[#1A1A2E] mb-1">{step.title}</h3>
                <p class="text-[#555555]">{step.desc}</p>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <!-- Pull quote -->
    <section class="py-14 px-4 bg-white border-t border-[#DDDDDD]">
      <div class="max-w-3xl mx-auto text-center">
        <blockquote class="text-2xl md:text-3xl font-bold text-[#1A1A2E] leading-snug" style="font-family: var(--font-family-display);">
          Traceability doesn't need to cost six figures.
        </blockquote>
      </div>
    </section>

    <!-- Social Proof / Credibility -->
    <section class="py-10 px-4 bg-[#1A1A2E]">
      <div class="max-w-4xl mx-auto text-center">
        <p class="text-white/80 text-base">
          Used by quality engineers at medical device, aerospace, and automotive companies.
          Built by people who've written RTMs at 11pm the night before an audit.
        </p>
      </div>
    </section>

    <!-- MCP Teaser -->
    <section class="py-20 px-4 bg-[#0F0F0F]">
      <div class="max-w-6xl mx-auto">
        <div class="grid md:grid-cols-2 gap-12 md:gap-16 items-center">

          <!-- Left: Quote + CTA -->
          <div>
            <p class="text-xs font-semibold text-gray-600 uppercase tracking-widest mb-5" style="font-family: var(--font-family-mono);">RTMify Live · MCP</p>
            <blockquote class="text-2xl md:text-3xl font-bold text-white leading-snug mb-5" style="font-family: var(--font-family-display);">
              "I'm literally talking to my requirements. Jama, Polarion... nobody has this feature."
            </blockquote>
            <p class="text-gray-500 mb-8 text-sm" style="font-family: var(--font-family-mono);">— RTMify Live user, via Claude Code</p>
            <p class="text-gray-400 mb-8">
              Your RTM isn't a static document you update before audits. With RTMify Live, it's a live knowledge graph you can talk to.
            </p>
            <a
              href="/live"
              class="inline-flex items-center gap-2 text-white text-sm font-semibold border border-white/20 hover:border-white/50 hover:bg-white/5 px-5 py-3 rounded-lg transition-all duration-200"
            >
              See RTMify Live →
            </a>
          </div>

          <!-- Right: Mini terminal -->
          <div class="relative">
            <ConversationDemo mini={true} />
          </div>

        </div>
      </div>
    </section>

    <!-- Standards deep-dives -->
    <section class="py-16 px-4 bg-[#F5F5F5]">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-2xl font-bold text-[#1A1A2E] text-center mb-4">Standard-specific guidance</h2>
        <p class="text-[#555555] text-center mb-10 max-w-2xl mx-auto">The template covers all six standards. Each standards page explains exactly what the standard requires, what the template covers, and where teams typically miss.</p>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {standards.map(s => (
            <a
              href={`/standards/${s.slug}`}
              class="group block border border-[#DDDDDD] rounded-lg p-5 bg-white hover:-translate-y-1 hover:shadow-lg transition-all duration-200"
              style={`border-left: 4px solid ${s.color};`}
            >
              <div
                class="inline-flex items-center px-2 py-0.5 rounded text-xs font-bold text-white mb-3"
                style={`background-color: ${s.color};`}
              >
                {s.label}
              </div>
              <h3 class="font-semibold text-[#1A1A2E] group-hover:underline mb-1">{s.label} RTM Template</h3>
              <p class="text-sm text-[#555555]">{s.desc}</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Footer CTA -->
    <section class="py-16 px-4 bg-[#1A1A2E] text-center">
      <div class="max-w-2xl mx-auto">
        <h2 class="text-2xl font-bold text-white mb-3">Download the template</h2>
        <p class="text-gray-300 mb-6">Free. No account. No email. Works in Excel and Google Sheets.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
          <DownloadButton size="lg" variant="light" />
          <a href="/about" class="text-gray-300 hover:text-white transition-colors">
            Learn about RTMify →
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
