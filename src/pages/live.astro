---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ProductLadder from '../components/ProductLadder.astro';
import ConversationDemo from '../components/ConversationDemo.astro';
---

<BaseLayout
  title="RTMify Live — Continuous Requirements Traceability with Git Integration and MCP"
  description="RTMify Live keeps your RTM current automatically. 30-second sync to Google Sheets, git blame traceability, industry profiles, and a native MCP server so you can talk to your requirements with AI."
>
  <Nav />

  <main class="flex-1">
    <!-- Hero -->
    <section class="bg-[#1A1A2E] text-white py-20 px-4">
      <div class="max-w-3xl mx-auto">
        <p class="text-sm font-semibold text-gray-400 uppercase tracking-widest mb-3">RTMify Live</p>
        <h1 class="text-4xl md:text-5xl font-bold mb-5 tracking-tight" style="font-family: var(--font-family-display);">
          Your RTM. Always current.
        </h1>
        <p class="text-lg text-gray-300 mb-6 max-w-2xl">
          Live sync to your Google Sheet. Git blame traceability from requirement to commit. A native MCP server so your AI assistant can answer questions about your requirements in real time.
        </p>
      </div>
    </section>

    <!-- MCP Conversation Demo -->
    <section class="py-20 px-4 bg-[#0F0F0F]">
      <div class="max-w-4xl mx-auto">
        <p class="text-xs font-semibold text-gray-600 uppercase tracking-widest mb-4 text-center" style="font-family: var(--font-family-mono);">RTMify Live · MCP Demo</p>
        <h2 class="text-3xl md:text-4xl font-bold text-white text-center mb-3 tracking-tight" style="font-family: var(--font-family-display);">
          Ask your requirements anything.
        </h2>
        <p class="text-gray-500 text-center mb-12 max-w-lg mx-auto">
          No form. No export. No pivot table. Connect your AI assistant once — your entire requirements database becomes conversational.
        </p>
        <ConversationDemo />
      </div>
    </section>

    <!-- What it does — 4 feature blocks -->
    <section class="py-16 px-4 bg-white">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-2xl font-bold text-[#1A1A2E] mb-10">What Live does</h2>
        <div class="space-y-10">

          <div class="flex gap-5 items-start">
            <div class="w-9 h-9 rounded-full bg-[#1A1A2E] text-white font-bold flex items-center justify-center shrink-0 text-sm">1</div>
            <div>
              <h3 class="font-semibold text-[#1A1A2E] text-lg mb-2">Keeps your sheet current — automatically</h3>
              <p class="text-[#555555]">
                Connect Live to your Google Sheet and it polls every 30 seconds. When anyone edits a requirement, test, or risk, Live re-evaluates the full traceability chain and writes the result back: a color-coded status column on every row. Green for covered. Yellow for gaps. Red for errors. No manual updates. No stale RTMs. Your team keeps working in the spreadsheet they already use — Live runs in the background.
              </p>
            </div>
          </div>

          <div class="flex gap-5 items-start">
            <div class="w-9 h-9 rounded-full bg-[#1A1A2E] text-white font-bold flex items-center justify-center shrink-0 text-sm">2</div>
            <div>
              <h3 class="font-semibold text-[#1A1A2E] text-lg mb-2">Reads your git repo</h3>
              <p class="text-[#555555]">
                Point Live at your repository and it walks your source tree, finds every comment where a developer tagged a requirement ID — a simple annotation like <code class="text-[#1A1A2E] bg-gray-100 px-1.5 py-0.5 rounded text-sm" style="font-family: var(--font-family-mono);">// REQ-047</code>, no tooling change required — and runs <code class="text-[#1A1A2E] bg-gray-100 px-1.5 py-0.5 rounded text-sm" style="font-family: var(--font-family-mono);">git blame</code> on each one. The result is a live map from requirement to source file to author to commit. You can see exactly which requirements have been implemented, by whom, and when — and which haven't been touched since the spec was written.
              </p>
            </div>
          </div>

          <div class="flex gap-5 items-start">
            <div class="w-9 h-9 rounded-full bg-[#1A1A2E] text-white font-bold flex items-center justify-center shrink-0 text-sm">3</div>
            <div>
              <h3 class="font-semibold text-[#1A1A2E] text-lg mb-2">Talk to your requirements with AI</h3>
              <p class="text-[#555555]">
                Live runs a native MCP server (Model Context Protocol — the standard used by Claude, Cursor, and other AI clients). Connect your AI assistant once and your entire requirements database becomes conversational. Ask things like:
              </p>
              <ul class="mt-3 space-y-1 text-[#555555] list-none pl-0">
                <li class="flex gap-2"><span class="text-[#1A1A2E] font-semibold shrink-0">→</span> <em>"Which requirements have no test coverage?"</em></li>
                <li class="flex gap-2"><span class="text-[#1A1A2E] font-semibold shrink-0">→</span> <em>"What breaks if I change REQ-047?"</em></li>
                <li class="flex gap-2"><span class="text-[#1A1A2E] font-semibold shrink-0">→</span> <em>"Show me the full traceability chain for this user need."</em></li>
                <li class="flex gap-2"><span class="text-[#1A1A2E] font-semibold shrink-0">→</span> <em>"Who implemented this requirement and which commit?"</em></li>
                <li class="flex gap-2"><span class="text-[#1A1A2E] font-semibold shrink-0">→</span> <em>"List every unimplemented requirement in the safety-critical subsystem."</em></li>
              </ul>
              <p class="text-[#555555] mt-3">
                Your RTM goes from a document you update before audits to a knowledge base you can query any time.
              </p>
            </div>
          </div>

          <div class="flex gap-5 items-start">
            <div class="w-9 h-9 rounded-full bg-[#1A1A2E] text-white font-bold flex items-center justify-center shrink-0 text-sm">4</div>
            <div>
              <h3 class="font-semibold text-[#1A1A2E] text-lg mb-2">Knows your standard</h3>
              <p class="text-[#555555]">
                Pick a profile and Live enforces the right traceability chain for your regulatory context. Each profile checks the gaps that actually matter for your standard — not a generic list.
              </p>
              <div class="mt-4 grid sm:grid-cols-2 gap-3">
                <div class="border border-[#DDDDDD] rounded-lg p-4">
                  <p class="font-semibold text-[#1A1A2E] text-sm mb-1">Medical</p>
                  <p class="text-xs text-[#555555]">ISO 13485 / IEC 62304 / FDA. Full Design Input → Output → Source chain. Risk mitigation linkage.</p>
                </div>
                <div class="border border-[#DDDDDD] rounded-lg p-4">
                  <p class="font-semibold text-[#1A1A2E] text-sm mb-1">Aerospace</p>
                  <p class="text-xs text-[#555555]">AS9100 / DO-178C. HLR/LLR decomposition. Structural coverage evidence. DAL annotation.</p>
                </div>
                <div class="border border-[#DDDDDD] rounded-lg p-4">
                  <p class="font-semibold text-[#1A1A2E] text-sm mb-1">Automotive</p>
                  <p class="text-xs text-[#555555]">ISO 26262 / ASPICE. ASIL assignment and inheritance checks. HARA linkage.</p>
                </div>
                <div class="border border-[#DDDDDD] rounded-lg p-4">
                  <p class="font-semibold text-[#1A1A2E] text-sm mb-1">Generic</p>
                  <p class="text-xs text-[#555555]">No required chain. User Needs, Requirements, Tests, Risks. Start here and tighten later.</p>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- The problem it solves -->
    <section class="py-16 px-4 bg-[#F5F5F5] border-t border-[#DDDDDD]">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-2xl font-bold text-[#1A1A2E] mb-6">Why not just use Jama?</h2>
        <p class="text-[#555555] mb-4">
          Most teams that buy Jama or Polarion end up with two systems: the ALM tool the program manager uses for reports, and the spreadsheet everyone actually trusts. You've paid for enterprise software and still have engineers maintaining an Excel file on the side. It's so common it has a name: shelfware.
        </p>
        <p class="text-[#555555] mb-8">
          RTMify Live doesn't ask your team to change how they work. The spreadsheet stays. Live runs alongside it — reading it, validating it, connecting it to your source code, and making it queryable by AI. The spreadsheet becomes the source of truth it was always supposed to be.
        </p>
        <div class="overflow-x-auto">
          <table class="w-full text-sm border-collapse">
            <thead>
              <tr class="bg-[#1A1A2E] text-white">
                <th class="text-left px-4 py-3 font-semibold">Feature</th>
                <th class="text-left px-4 py-3 font-semibold">Legacy ALM (Jama / Polarion)</th>
                <th class="text-left px-4 py-3 font-semibold">RTMify Live</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-b border-[#DDDDDD]">
                <td class="px-4 py-3 font-medium text-[#1A1A2E]">Learning curve</td>
                <td class="px-4 py-3 text-[#555555]">2-week "certification"</td>
                <td class="px-4 py-3 text-[#555555]">0 minutes — it's Excel</td>
              </tr>
              <tr class="border-b border-[#DDDDDD] bg-white">
                <td class="px-4 py-3 font-medium text-[#1A1A2E]">Data privacy</td>
                <td class="px-4 py-3 text-[#555555]">Cloud, or complex on-prem</td>
                <td class="px-4 py-3 text-[#555555]">100% local / your repo</td>
              </tr>
              <tr class="border-b border-[#DDDDDD]">
                <td class="px-4 py-3 font-medium text-[#1A1A2E]">Traceability</td>
                <td class="px-4 py-3 text-[#555555]">Manual linking</td>
                <td class="px-4 py-3 text-[#555555]">Auto-mapped via git blame</td>
              </tr>
              <tr class="border-b border-[#DDDDDD] bg-white">
                <td class="px-4 py-3 font-medium text-[#1A1A2E]">AI-ready?</td>
                <td class="px-4 py-3 text-[#555555]">No / "Beta"</td>
                <td class="px-4 py-3 text-[#555555]">Native MCP server</td>
              </tr>
              <tr>
                <td class="px-4 py-3 font-medium text-[#1A1A2E]">What engineers actually use</td>
                <td class="px-4 py-3 text-[#555555]">Excel (on the side)</td>
                <td class="px-4 py-3 text-[#555555]">Excel (that's the whole point)</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <ProductLadder current="live" />
  </main>

  <Footer />
</BaseLayout>
