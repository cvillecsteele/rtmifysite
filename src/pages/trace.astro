---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="RTMify Trace — Generate a Requirements Traceability Matrix from Your Spreadsheet"
  description="RTMify Trace is a local tool that reads your .xlsx requirements spreadsheet and generates a complete PDF, Markdown, or DOCX traceability matrix. Nothing uploaded. No account."
>
  <Nav />

  <main class="flex-1">
    <!-- Hero -->
    <section class="bg-[#1A1A2E] text-white py-20 px-4">
      <div class="max-w-3xl mx-auto">
        <p class="text-sm font-semibold text-gray-400 uppercase tracking-widest mb-3">RTMify Trace</p>
        <h1 class="text-4xl md:text-5xl font-bold mb-5 tracking-tight">
          Drag. Drop. Done.
        </h1>
        <p class="text-lg text-gray-300 mb-6 max-w-2xl">
          A local tool that generates a complete requirements traceability matrix from your spreadsheet.
          Drag your <code class="text-white bg-white/10 px-1.5 py-0.5 rounded text-base">.xlsx</code> file onto RTMify Trace and get a PDF, Markdown, or DOCX traceability artifact — on your machine, with nothing uploaded.
        </p>
        <p class="text-gray-400 text-sm">RTMify Trace is in development. Join the waitlist below.</p>
      </div>
    </section>

    <!-- What it does -->
    <section class="py-16 px-4 bg-white">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-2xl font-bold text-[#1A1A2E] mb-8">What RTMify Trace does</h2>
        <div class="space-y-6">
          <div class="flex gap-5 items-start">
            <div class="w-9 h-9 rounded-full bg-[#1A1A2E] text-white font-bold flex items-center justify-center shrink-0 text-sm">1</div>
            <div>
              <h3 class="font-semibold text-[#1A1A2E] mb-1">Read your spreadsheet</h3>
              <p class="text-[#555555]">Trace reads the four-tab schema from your RTMify Template: User Needs, Requirements, Tests, Risks — and all the cross-reference IDs between them.</p>
            </div>
          </div>
          <div class="flex gap-5 items-start">
            <div class="w-9 h-9 rounded-full bg-[#1A1A2E] text-white font-bold flex items-center justify-center shrink-0 text-sm">2</div>
            <div>
              <h3 class="font-semibold text-[#1A1A2E] mb-1">Resolve the traceability chain</h3>
              <p class="text-[#555555]">Every requirement is linked to its originating user need, covering tests, and associated risks. Trace resolves the full bidirectional chain and surfaces any gaps.</p>
            </div>
          </div>
          <div class="flex gap-5 items-start">
            <div class="w-9 h-9 rounded-full bg-[#1A1A2E] text-white font-bold flex items-center justify-center shrink-0 text-sm">3</div>
            <div>
              <h3 class="font-semibold text-[#1A1A2E] mb-1">Generate the artifact</h3>
              <p class="text-[#555555]">Output a PDF, Markdown, or DOCX requirements traceability matrix — formatted for inclusion in a technical file, design history file, or audit package. Print it. Email it. Archive it.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Why local -->
    <section class="py-16 px-4 bg-[#F5F5F5] border-t border-[#DDDDDD]">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-2xl font-bold text-[#1A1A2E] mb-6">Runs locally. Nothing uploaded.</h2>
        <p class="text-[#555555] mb-4">
          For engineers at companies where "upload it to a cloud service" isn't an option — defense contractors, medical device manufacturers, regulated financial firms — this is the point. Trace runs on your machine. No network connection required. No account. No telemetry.
        </p>
        <p class="text-[#555555]">
          RTMify Trace is a self-serve tool provided as-is. It does one thing well: turns your spreadsheet relationships into a properly formatted traceability document. No support or configuration needed.
        </p>
      </div>
    </section>

    <!-- Waitlist -->
    <section class="py-16 px-4 bg-white border-t border-[#DDDDDD]">
      <div class="max-w-md mx-auto text-center">
        <h2 class="text-2xl font-bold text-[#1A1A2E] mb-3">Get notified when it ships</h2>
        <p class="text-[#555555] mb-8">Mac, Windows, and Linux. One email when it's ready. No marketing.</p>
        <form
          action="https://submit-form.com/rtmify-binary-waitlist"
          method="POST"
          class="flex gap-3"
        >
          <input
            type="email"
            name="email"
            required
            placeholder="you@company.com"
            class="flex-1 px-4 py-2.5 border border-[#DDDDDD] rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[#1A1A2E] focus:border-transparent"
          />
          <button
            type="submit"
            class="px-5 py-2.5 bg-[#1A1A2E] text-white text-sm font-semibold rounded-lg hover:bg-[#2A2A4E] transition-colors whitespace-nowrap"
          >
            Notify me
          </button>
        </form>
      </div>
    </section>

    <!-- Product ladder -->
    <section class="py-16 px-4 bg-[#F5F5F5] border-t border-[#DDDDDD]">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-2xl font-bold text-[#1A1A2E] mb-8">The RTMify product ladder</h2>
        <div class="space-y-4">
          <div class="bg-white border border-[#DDDDDD] rounded-lg p-5 flex items-start gap-4">
            <div class="shrink-0 w-8 h-8 bg-[#1A1A2E] rounded flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            </div>
            <div>
              <a href="/download" class="font-semibold text-[#1A1A2E] hover:underline">RTMify Template</a>
              <p class="text-sm text-[#555555] mt-0.5">Build your RTM in a spreadsheet. Free download, no account.</p>
            </div>
          </div>
          <div class="bg-white border-2 border-[#1A1A2E] rounded-lg p-5 flex items-start gap-4">
            <div class="shrink-0 w-8 h-8 bg-[#1A1A2E] rounded flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
            </div>
            <div>
              <span class="font-semibold text-[#1A1A2E]">RTMify Trace</span>
              <span class="ml-2 text-xs font-medium text-white bg-[#1A1A2E] px-2 py-0.5 rounded-full">You are here</span>
              <p class="text-sm text-[#555555] mt-0.5">Generate a complete traceability artifact from your spreadsheet. Local, offline, no account.</p>
            </div>
          </div>
          <div class="bg-white border border-[#DDDDDD] rounded-lg p-5 flex items-start gap-4 opacity-60">
            <div class="shrink-0 w-8 h-8 bg-[#2A2A4E] rounded flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div>
              <a href="/live" class="font-semibold text-[#1A1A2E] hover:underline">RTMify Live</a>
              <span class="ml-2 text-xs font-medium text-[#555555] border border-[#DDDDDD] px-2 py-0.5 rounded-full">Coming later</span>
              <p class="text-sm text-[#555555] mt-0.5">Maintain traceability continuously. Live sync to your Google Sheet.</p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
