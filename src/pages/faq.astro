---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="FAQ — RTMify"
  description="Common questions about RTMify, support, and consulting engagements."
>
  <Nav />

  <main class="flex-1">
    <!-- Hero -->
    <section class="bg-[#1A1A2E] text-white py-16 px-4">
      <div class="max-w-3xl mx-auto">
        <h1 class="text-3xl md:text-4xl font-bold mb-3" style="font-family: var(--font-family-display);">Common questions</h1>
        <p class="text-gray-300 text-lg">Everything you need to know about RTMify.</p>
      </div>
    </section>

    <div class="py-16 px-4">
      <div class="max-w-3xl mx-auto space-y-6">

        <div class="pl-4 border-l-2 border-[#DDDDDD]">
          <h2 class="font-semibold text-[#1A1A2E] mb-1">Is support available?</h2>
          <p class="text-[#555555]">RTMify is a self-serve tool. The template and RTMify Trace are provided as-is, with no onboarding, customization, or support included. If you can fill in a spreadsheet, you can use it.</p>
        </div>

        <div class="pl-4 border-l-2 border-[#DDDDDD]">
          <h2 class="font-semibold text-[#1A1A2E] mb-1">What if we need expert help?</h2>
          <p class="text-[#555555]">Consulting engagements are available at $5,000/day with a signed MSA. <a href="mailto:hello@rtmify.io" class="underline hover:text-[#1A1A2E]">Email us</a> with a brief description of the engagement.</p>
        </div>

      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
