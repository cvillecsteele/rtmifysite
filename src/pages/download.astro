---
import { readFileSync } from 'node:fs';
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import DownloadButton from '../components/DownloadButton.astro';
import ProductLadder from '../components/ProductLadder.astro';

type DownloadAsset = {
  product: string;
  platform: string;
  version: string;
  path: string;
  filename: string;
  kind: string;
  sha256: string;
  url: string;
};

type DownloadManifest = {
  version: string | null;
  tag: string | null;
  releaseUrl: string | null;
  repo: string | null;
  assets: DownloadAsset[];
};

function loadDownloadManifest(): DownloadManifest {
  try {
    const path = new URL('../../public/downloads/latest.json', import.meta.url);
    return JSON.parse(readFileSync(path, 'utf-8'));
  } catch {
    return {
      version: null,
      tag: null,
      releaseUrl: null,
      repo: null,
      assets: [],
    };
  }
}

function platformLabel(platform: string): string {
  switch (platform) {
    case 'macos':
      return 'macOS';
    case 'windows':
      return 'Windows';
    case 'linux':
      return 'Linux';
    default:
      return platform;
  }
}

function productLabel(product: string): string {
  switch (product) {
    case 'trace':
      return 'RTMify Trace';
    case 'live':
      return 'RTMify Live';
    default:
      return product;
  }
}

function kindLabel(kind: string): string {
  switch (kind) {
    case 'pkg':
      return '.pkg installer';
    case 'exe':
      return '.exe download';
    case 'tar.gz':
      return '.tar.gz archive';
    default:
      return kind;
  }
}

const downloadManifest = loadDownloadManifest();
const installerKindOrder = { pkg: 0, exe: 1, 'tar.gz': 2 };
const platformOrder = { macos: 0, windows: 1, linux: 2, any: 3 };

const installerAssets = downloadManifest.assets
  .filter((asset) => ['pkg', 'exe', 'tar.gz'].includes(asset.kind) && ['trace', 'live'].includes(asset.product))
  .sort((left, right) => {
    const leftPlatform = platformOrder[left.platform as keyof typeof platformOrder] ?? 9;
    const rightPlatform = platformOrder[right.platform as keyof typeof platformOrder] ?? 9;
    if (leftPlatform !== rightPlatform) return leftPlatform - rightPlatform;
    const leftKind = installerKindOrder[left.kind as keyof typeof installerKindOrder] ?? 9;
    const rightKind = installerKindOrder[right.kind as keyof typeof installerKindOrder] ?? 9;
    if (leftKind !== rightKind) return leftKind - rightKind;
    return left.filename.localeCompare(right.filename);
  });

const utilityAssets = downloadManifest.assets.filter((asset) =>
  ['checksums.txt', 'package-manifest.json', 'manifest.json'].includes(asset.filename)
);

const softwareSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'RTMify Downloads',
  description: 'RTMify desktop installers and free requirements traceability templates for regulated industries.',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Windows, macOS, Linux',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  url: 'https://rtmify.io/download',
};
---

<BaseLayout
  title="Free Requirements Traceability Matrix Excel Template | RTMify"
  description="Four-tab RTM spreadsheet for AS9100, ISO 13485, DO-178C, IEC 62304, and ISO 26262. Works in Excel and Google Sheets. No account, no email required."
  jsonLd={softwareSchema}
>
  <Nav />

  <main class="flex-1">
    <!-- Hero -->
    <section class="bg-[#1A1A2E] text-white py-16 px-4">
      <div class="max-w-3xl mx-auto">
        <h1 class="text-3xl md:text-4xl font-bold mb-3" style="font-family: var(--font-family-display);">Free requirements traceability templates</h1>
        <p class="text-gray-300 text-lg">Free template. Nothing requires an account or an email address.</p>
      </div>
    </section>

    <section class="py-16 px-4 bg-[#F8F9FB] border-b border-[#E5E7EB]">
      <div class="max-w-3xl mx-auto">
        <div class="flex items-start gap-4 mb-6">
          <div class="w-12 h-12 bg-[#1A1A2E] rounded-lg flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
              <polyline points="7 10 12 15 17 10"/>
              <line x1="12" y1="15" x2="12" y2="3"/>
            </svg>
          </div>
          <div class="flex-1">
            <h2 class="text-2xl font-bold text-[#1A1A2E] mb-2">Desktop installers</h2>
            {downloadManifest.version ? (
              <p class="text-[#555555]">
                Latest published release: <span class="font-semibold text-[#1A1A2E]">{downloadManifest.version}</span>
                {downloadManifest.releaseUrl && (
                  <>
                    {' '}
                    <a href={downloadManifest.releaseUrl} class="font-semibold text-[#1A1A2E] underline underline-offset-2 hover:opacity-70 transition-opacity">view release notes</a>
                  </>
                )}
              </p>
            ) : (
              <p class="text-[#555555]">Installer links appear here after the first packaged GitHub Release is published.</p>
            )}
          </div>
        </div>

        {installerAssets.length > 0 ? (
          <>
            <div class="space-y-4 mb-6">
              {installerAssets.map((asset) => (
                <div class="bg-white border border-[#DDDDDD] rounded-xl p-6 flex flex-col sm:flex-row sm:items-center gap-4">
                  <div class="flex-1">
                    <p class="text-xs uppercase tracking-[0.18em] text-[#1A1A2E] font-semibold mb-2">{platformLabel(asset.platform)}</p>
                    <h3 class="text-lg font-bold text-[#1A1A2E] mb-1">{productLabel(asset.product)}</h3>
                    <p class="text-sm text-[#555555] mb-2">{kindLabel(asset.kind)} &middot; {asset.filename}</p>
                    <p class="text-xs text-[#777777] font-mono break-all">SHA-256: {asset.sha256}</p>
                  </div>
                  <a
                    href={asset.url}
                    class="inline-flex items-center justify-center px-5 py-3 rounded-lg bg-[#1A1A2E] text-white font-semibold hover:bg-[#2A2A4E] transition-colors"
                  >
                    Download
                  </a>
                </div>
              ))}
            </div>

            {utilityAssets.length > 0 && (
              <div class="flex flex-wrap gap-4 text-sm">
                {utilityAssets.map((asset) => (
                  <a href={asset.url} class="text-[#1A1A2E] font-semibold hover:underline">
                    {asset.filename}
                  </a>
                ))}
              </div>
            )}
          </>
        ) : null}
      </div>
    </section>

    <!-- Cards -->
    <div class="py-16 px-4">
      <div class="max-w-3xl mx-auto">

        <!-- Primary: XLSX Template -->
        <div class="bg-white border border-[#DDDDDD] rounded-xl p-8 mb-6">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-[#1A1A2E] rounded-lg flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
              </svg>
            </div>
            <div class="flex-1">
              <h2 class="text-xl font-bold text-[#1A1A2E] mb-1">RTMify Requirements Tracking Template</h2>
              <p class="text-[#555555] mb-1">Version 1.0 &middot; .xlsx format</p>
              <p class="text-sm text-[#555555] mb-5">
                Four tabs: User Needs, Requirements, Tests, Risks. Covers AS9100, ISO 13485, DO-178C, IEC 62304, ISO 26262, and Automotive SPICE.
                Works in Microsoft Excel and Google Sheets. The README tab explains the schema.
              </p>
              <DownloadButton size="md" />
            </div>
          </div>
        </div>

        <!-- Design BOM Template -->
        <div class="bg-white border border-[#DDDDDD] rounded-xl p-8 mb-6">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-[#2E7D32] rounded-lg flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
                <path d="M8 13h8"/>
                <path d="M8 17h8"/>
              </svg>
            </div>
            <div class="flex-1">
              <h2 class="text-xl font-bold text-[#1A1A2E] mb-1">RTMify Design BOM Template</h2>
              <p class="text-[#555555] mb-1">Version 1.0 &middot; .xlsx format</p>
              <p class="text-sm text-[#555555] mb-5">
                Product and Design BOM tabs for Live DesignBOM ingestion, grouped workbook uploads, and secondary Design BOM sync. Includes the README reference tab and example BOM rows with requirement and test trace fields.
              </p>
              <div class="flex flex-wrap gap-3">
                <DownloadButton href="/RTMify_Design_BOM_Template.xlsx" label="Download Design BOM Template (.xlsx)" size="md" />
                <a href="/bom-template" class="inline-flex items-center px-6 py-3 rounded-lg border border-[#2E7D32] text-[#2E7D32] font-semibold hover:bg-[#F1F8F2] transition-colors">
                  View BOM Template Guide
                </a>
              </div>
            </div>
          </div>
        </div>

        <!-- SOUP Template -->
        <div class="bg-white border border-[#DDDDDD] rounded-xl p-8 mb-6">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-[#1565C0] rounded-lg flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
                <path d="M8 13h8"/>
                <path d="M8 17h5"/>
              </svg>
            </div>
            <div class="flex-1">
              <h2 class="text-xl font-bold text-[#1A1A2E] mb-1">RTMify SOUP Template</h2>
              <p class="text-[#555555] mb-1">Version 1.0 &middot; .xlsx format</p>
              <p class="text-sm text-[#555555] mb-5">
                Single-purpose software inventory workbook for Live SOUP ingestion and SOUP Sync. Tracks component name, version, supplier, license, safety class, known anomalies, anomaly evaluation, and direct requirement/test trace fields.
              </p>
              <div class="flex flex-wrap gap-3">
                <DownloadButton href="/RTMify_SOUP_Template.xlsx" label="Download SOUP Template (.xlsx)" size="md" />
                <a href="/soup-template" class="inline-flex items-center px-6 py-3 rounded-lg border border-[#1565C0] text-[#1565C0] font-semibold hover:bg-[#EFF6FF] transition-colors">
                  View SOUP Template Guide
                </a>
              </div>
            </div>
          </div>
        </div>

        <!-- Free Templates -->
        <div class="bg-[#F5F5F5] border border-[#DDDDDD] rounded-xl px-8 py-5 mb-6 flex flex-col sm:flex-row sm:items-center gap-3">
          <div class="flex-1">
            <p class="text-sm text-[#555555]">Looking for standalone risk analysis or SOUP templates? <a href="/free-templates" class="text-[#1A1A2E] font-semibold underline underline-offset-2 hover:opacity-70 transition-opacity">Browse free compliance templates →</a></p>
          </div>
        </div>

        <!-- RTMify Trace -->
        <a href="/pricing" class="block bg-white border border-[#DDDDDD] rounded-xl p-8 mb-6 hover:shadow-md transition-shadow group">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-[#2A2A4E] rounded-lg flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
              </svg>
            </div>
            <div class="flex-1">
              <h2 class="text-xl font-bold text-[#1A1A2E] mb-1 group-hover:underline">RTMify Trace</h2>
              <p class="text-[#555555] mb-1">Mac / Windows / Linux.</p>
              <p class="text-sm text-[#555555]">
                Drop your .xlsx on RTMify Trace. Get a PDF, Markdown, or DOCX traceability matrix. Runs locally with nothing uploaded and no account required.
              </p>
              <p class="text-sm text-[#1A1A2E] font-semibold mt-4">See pricing →</p>
            </div>
          </div>
        </a>

        <!-- Tool Qualification Package (IQ/OQ) -->
        <div class="bg-white border border-[#DDDDDD] rounded-xl p-8">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-[#2E7D32] rounded-lg flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M9 11l3 3L22 4"/>
                <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
              </svg>
            </div>
            <div class="flex-1">
              <h2 class="text-xl font-bold text-[#1A1A2E] mb-1">Tool Qualification Package (IQ/OQ)</h2>
              <p class="text-sm text-[#555555] mb-5">Every Trace and Live purchase includes a versioned IQ/OQ validation package for your quality records.</p>

              <div class="overflow-x-auto mb-5">
                <table class="w-full text-sm border-collapse">
                  <thead>
                    <tr class="border-b border-[#DDDDDD]">
                      <th class="text-left py-2 pr-4 font-semibold text-[#1A1A2E] w-2/5">File</th>
                      <th class="text-left py-2 font-semibold text-[#1A1A2E]">What it is</th>
                    </tr>
                  </thead>
                  <tbody class="text-[#555555]">
                    <tr class="border-b border-[#EEEEEE]">
                      <td class="py-2 pr-4 font-mono text-xs">OQ fixture (.xlsx)</td>
                      <td class="py-2">Controlled workbook with 25 items across 4 tabs. Contains intentional gaps, intentional warnings, and valid chains for positive verification.</td>
                    </tr>
                    <tr class="border-b border-[#EEEEEE]">
                      <td class="py-2 pr-4 font-mono text-xs">Golden outputs (PDF, DOCX, MD, JSON)</td>
                      <td class="py-2">Pre-verified reference outputs generated by RTMify against the fixture</td>
                    </tr>
                    <tr class="border-b border-[#EEEEEE]">
                      <td class="py-2 pr-4 font-mono text-xs">IQ/OQ Protocol (PDF)</td>
                      <td class="py-2">Step-by-step procedure with numbered checkpoints, pass/fail fields, signature blocks</td>
                    </tr>
                    <tr class="border-b border-[#EEEEEE]">
                      <td class="py-2 pr-4 font-mono text-xs">Evidence Record (PDF)</td>
                      <td class="py-2">Blank form your team completes and files as the quality record</td>
                    </tr>
                    <tr>
                      <td class="py-2 pr-4 font-mono text-xs">checksums.txt</td>
                      <td class="py-2">SHA-256 hashes of all platform binaries for installation verification</td>
                    </tr>
                  </tbody>
                </table>
              </div>

              <p class="text-sm text-[#555555] mb-5">Version-locked to each release. Machine-diffable JSON gap oracle. The protocol is self-contained. No external documents are required to execute it.</p>

              <div class="flex flex-wrap gap-4 text-sm">
                <a href="/validation" class="text-[#1A1A2E] font-semibold hover:underline">Learn more about tool qualification →</a>
                <a href="mailto:hello@rtmify.io" class="text-[#555555] hover:text-[#1A1A2E] hover:underline">Need a custom protocol?</a>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>

    <ProductLadder current="template" />
  </main>

  <Footer />
</BaseLayout>
