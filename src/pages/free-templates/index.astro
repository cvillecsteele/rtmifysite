---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import DownloadButton from '../../components/DownloadButton.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'RTMify', item: { "@id": "https://rtmify.io/" } },
        { '@type': 'ListItem', position: 2, name: 'Free Templates', item: { "@id": "https://rtmify.io/free-templates" } },
      ],
    },
    {
      '@type': 'ItemList',
      name: 'Free Compliance and Regulatory Templates',
      description: 'Free downloadable spreadsheet templates for regulated-industry engineering. No account required.',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'FMEA Template', url: 'https://rtmify.io/free-templates/fmea' },
        { '@type': 'ListItem', position: 2, name: 'Hazard Log Template', url: 'https://rtmify.io/free-templates/hazard-log' },
        { '@type': 'ListItem', position: 3, name: 'Risk Management Plan Template', url: 'https://rtmify.io/free-templates/risk-management-plan' },
        { '@type': 'ListItem', position: 4, name: 'V&V Plan Template', url: 'https://rtmify.io/free-templates/vv-plan' },
        { '@type': 'ListItem', position: 5, name: 'SOUP Template', url: 'https://rtmify.io/soup-template' },
        { '@type': 'ListItem', position: 6, name: 'Design BOM Template', url: 'https://rtmify.io/bom-template' },
      ],
    },
    {
      '@type': 'FAQPage',
      mainEntity: [
        {
          '@type': 'Question',
          name: 'What does an ISO 14971 risk management plan template include?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'An ISO 14971:2019 risk management plan must include: the scope of risk management activities, assignment of responsibilities, risk acceptability criteria (severity and probability scales, the risk evaluation matrix, and criteria for when probability cannot be estimated), the method for evaluating overall residual risk, requirements for risk control verification, review milestones, and post-production monitoring requirements. The RTMify Risk Management Plan template covers all seven Clause 4.4 requirements in a ready-to-fill Word document.',
          },
        },
        {
          '@type': 'Question',
          name: 'What templates are required for ISO 14971 medical device risk management?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'ISO 14971 requires maintaining a risk management file throughout the product lifecycle. The two core artifacts are a hazard log (tracking all identified hazards, risk controls, verification status, and residual risk acceptability) and an FMEA (bottom-up failure mode analysis for specific components and functions). Both are available as free downloads here with no account required.',
          },
        },
        {
          '@type': 'Question',
          name: 'Do I need any software to use these templates?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'No. Spreadsheet templates are standalone .xlsx workbooks that work in Microsoft Excel or Google Sheets. The V&V Plan template is a .docx Word document. No account, no subscription, and no email address is required to download any of them.',
          },
        },
        {
          '@type': 'Question',
          name: 'What is the difference between the FMEA template and the hazard log template?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'The FMEA template is a bottom-up analysis method that identifies failure modes for specific components or functions and scores them with Severity × Occurrence × Detection. The hazard log is a top-level register that tracks all identified hazards through the full risk management lifecycle: evaluation, control, verification, and final acceptability determination. FMEA findings feed the hazard log — the Linked FMEA ID column creates the explicit trace between the two documents.',
          },
        },
      ],
    },
  ],
};

const templates = [
  {
    name: 'FMEA Template',
    subtitle: 'Failure Mode and Effects Analysis',
    desc: 'ISO 14971 risk analysis with Severity × Occurrence × Detection scoring, RPN, recommended actions, mitigation tracking, and cross-references to the RTM requirements and risk register. Covers medical device, aerospace, automotive, and software contexts.',
    standards: ['ISO 14971', 'ISO 13485', 'IEC 62304', 'AS9100', 'ISO 26262'],
    downloadHref: '/RTMify_FMEA_Template.xlsx',
    downloadLabel: 'Download (.xlsx)',
    guideHref: '/free-templates/fmea',
  },
  {
    name: 'Hazard Log Template',
    subtitle: 'ISO 14971 Hazard Register',
    desc: 'Top-level hazard register for ISO 14971 risk management. Tracks hazards, hazardous situations, potential harm, initial and residual risk levels (Severity × Probability), risk control measures with type classification, verification status, and ALARP justification. Includes a 5×5 Risk Matrix tab with Acceptable / ALARP / Unacceptable levels.',
    standards: ['ISO 14971', 'ISO 13485', 'IEC 62304', 'AS9100', 'ISO 26262'],
    downloadHref: '/RTMify_Hazard_Log_Template.xlsx',
    downloadLabel: 'Download (.xlsx)',
    guideHref: '/free-templates/hazard-log',
  },
  {
    name: 'Risk Management Plan Template',
    subtitle: 'ISO 14971:2019 Risk Management Plan',
    desc: 'ISO 14971:2019 compliant Risk Management Plan covering scope, roles and responsibilities, risk acceptability criteria (5×5 matrix with Acceptable / ALARP / Unacceptable), risk control verification, lifecycle review milestones, post-production monitoring, and a full traceability chain from hazard to test report. Word document (.docx).',
    standards: ['ISO 14971', 'ISO 13485', 'IEC 62304', 'EU MDR', 'FDA QMSR'],
    downloadHref: '/RTMify_Risk_Management_Plan_Template.docx',
    downloadLabel: 'Download (.docx)',
    guideHref: '/free-templates/risk-management-plan',
  },
  {
    name: 'V&V Plan Template',
    subtitle: 'Verification and Validation Plan',
    desc: 'Structured V&V Plan covering verification and validation strategy, activity tables (VER-xxx / VAL-xxx IDs), four verification methods (Test / Analysis / Inspection / Demonstration), risk control verification per ISO 14971 §5.6, RTM traceability summary, and standard-specific guidance for ISO 13485, IEC 62304, DO-178C, ISO 26262, and AS9100.',
    standards: ['ISO 13485', 'ISO 14971', 'IEC 62304', 'DO-178C', 'ISO 26262', 'AS9100'],
    downloadHref: '/RTMify_VV_Plan_Template.docx',
    downloadLabel: 'Download (.docx)',
    guideHref: '/free-templates/vv-plan',
  },
  {
    name: 'SOUP Template',
    subtitle: 'Software of Unknown Provenance Register',
    desc: 'IEC 62304 SOUP register with component name, version, supplier, license, safety class, known anomalies, anomaly evaluation, and direct requirement and test references. Use standalone or connect to RTMify Live as a read-only SOUP source.',
    standards: ['IEC 62304', 'ISO 13485', 'DO-178C', 'AS9100', 'ISO 26262', 'ASPICE'],
    downloadHref: '/RTMify_SOUP_Template.xlsx',
    downloadLabel: 'Download (.xlsx)',
    guideHref: '/soup-template',
  },
  {
    name: 'Design BOM Template',
    subtitle: 'Design Bill of Materials',
    desc: 'Structured design-intent BOM with a Product tab and Design BOM tab. Hierarchy, quantity, supplier, part revision, and explicit requirement and test reference columns for typed trace links. Use standalone or connect to RTMify Live for BOM gaps, impact analysis, and MCP queries.',
    standards: ['AS9100', 'ISO 13485', 'DO-178C', 'IEC 62304', 'ISO 26262', 'ASPICE'],
    downloadHref: '/RTMify_Design_BOM_Template.xlsx',
    downloadLabel: 'Download (.xlsx)',
    guideHref: '/bom-template',
  },
];

---

<BaseLayout
  title="Free Compliance and Regulatory Templates — RTMify"
  description="Free downloadable templates for regulated-industry engineering: ISO 14971 risk management plan, FMEA, hazard log, V&V plan, SOUP register, and Design BOM. No account required."
  canonical="https://rtmify.io/free-templates"
  jsonLd={jsonLd}
>
  <Nav />

  <main class="flex-1">

    <section class="bg-[#163A2A] text-white py-16 px-4">
      <div class="max-w-3xl mx-auto">
        <h1 class="text-3xl md:text-4xl font-bold mb-3" style="font-family: var(--font-family-display);">Free compliance templates</h1>
        <p class="text-[#D8E7DD] text-lg mb-5">Standalone templates for risk management, SOUP tracking, and design-output documentation in medical device, aerospace, and automotive programs. Easy, free direct download. We don't even need your email.</p>
        <div class="flex flex-wrap gap-2 text-sm">
          {['ISO 14971', 'ISO 13485', 'IEC 62304', 'AS9100', 'ISO 26262', 'ASPICE'].map(s => (
            <span class="bg-white/10 border border-white/20 text-white px-2.5 py-0.5 rounded-full font-medium">{s}</span>
          ))}
        </div>
      </div>
    </section>

    <section class="py-16 px-4 bg-white">
      <div class="max-w-4xl mx-auto">

        <div class="space-y-6">
          {templates.map(t => (
            <div class="border border-[#DDDDDD] rounded-xl p-6 flex flex-col sm:flex-row sm:items-start gap-6">
              <div class="flex-1">
                <h2 class="text-lg font-bold text-[#1A1A2E] mb-0.5">{t.name}</h2>
                <p class="text-sm text-[#555555] mt-0 mb-3">{t.subtitle}</p>
                <p class="text-[#555555] text-sm mb-4">{t.desc}</p>
                <div class="flex flex-wrap gap-1.5">
                  {t.standards.map(s => (
                    <span class="text-xs font-medium text-[#555555] bg-[#F5F5F5] border border-[#DDDDDD] px-2 py-0.5 rounded">{s}</span>
                  ))}
                </div>
              </div>
              <div class="flex flex-col gap-2 shrink-0 sm:pt-1">
                <DownloadButton href={t.downloadHref} label={t.downloadLabel} size="sm" />
                <a href={t.guideHref} class="text-center text-sm text-[#555555] hover:text-[#1A1A2E] underline underline-offset-4 transition-colors">
                  Field guide →
                </a>
              </div>
            </div>
          ))}
        </div>

        <p class="text-sm text-[#555555] mt-8">More in development: Design History File, Test Case Specification, Configuration Item List, Change Impact Analysis, Requirements Review Checklist.</p>

      </div>
    </section>

    <section class="py-12 px-4 bg-[#F5F5F5] border-t border-[#DDDDDD]">
      <div class="max-w-4xl mx-auto flex flex-col sm:flex-row sm:items-center gap-6">
        <div class="flex-1">
          <h2 class="text-base font-bold text-[#1A1A2E] mb-1">The core RTM template</h2>
          <p class="text-sm text-[#555555]">The Requirements Tracking Template is the starting point for all six supported standards. These free templates are standalone artifacts designed to work alongside it.</p>
        </div>
        <DownloadButton size="sm" />
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>
